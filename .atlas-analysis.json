  "keyFeatures": [
    "End-to-end AES encrypted notes stored in the cloud",
    "JWT-based authentication with secure session management",
    "Password hashing with bcrypt",
    "Password recovery via email token (Nodemailer)",
    "Registration cancellation within 24 hours via email token",
    "In-browser rich text editor with Markdown/TXT/HTML export",
